  <script is:inline>
    // ============================================================
    // DASHBOARD STATE MACHINE
    // ============================================================

    // States: CONNECTING -> OPEN -> CLOSING -> CLOSED -> CONNECTING...
    const STATES = {
      CONNECTING: 'connecting',
      OPEN: 'open',
      CLOSING: 'closing',
      CLOSED: 'closed',
    };

    const STATE_DURATIONS = {
      [STATES.CONNECTING]: 1800,
      [STATES.OPEN]: 22000,
      [STATES.CLOSING]: 600,
      [STATES.CLOSED]: 1200,
    };

    const STATE_LABELS = {
      [STATES.CONNECTING]: 'CONNECTING',
      [STATES.OPEN]: 'OPEN',
      [STATES.CLOSING]: 'CLOSING',
      [STATES.CLOSED]: 'CLOSED',
    };

    let currentState = STATES.CONNECTING;
    let stateTimer = null;

    // ---- counters (reset on reconnect)
    let msgSent = 0;
    let msgRecv = 0;
    let frameText = 0;
    let frameBinary = 0;
    let framePingPong = 0; // single paired counter — PING and PONG always equal
    let uptimeSeconds = 0;
    let uptimeTimer = null;

    // ---- DOM refs
    const statusDot = document.getElementById('statusDot');
    const statusLabel = document.getElementById('statusLabel');
    const uptimeVal = document.getElementById('uptimeVal');
    const latencyEl = document.getElementById('latencyVal');
    const msgSentEl = document.getElementById('msgSent');
    const msgRecvEl = document.getElementById('msgRecv');
    const frameTextEl = document.getElementById('frameText');
    const frameBinEl = document.getElementById('frameBinary');
    const framePingEl = document.getElementById('framePing');
    const feedInner = document.getElementById('feedInner');

    function padZ(n) {
      return String(n).padStart(2, '0');
    }

    function fmtUptime(s) {
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      return `${padZ(h)}:${padZ(m)}:${padZ(sec)}`;
    }

    function applyState(state) {
      statusDot.className = `db-status-dot ${state}`;
      statusLabel.className = `db-status-label ${state}`;
      statusLabel.textContent = STATE_LABELS[state];
    }

    function resetCounters() {
      msgSent = 0;
      msgRecv = 0;
      frameText = 0;
      frameBinary = 0;
      framePingPong = 0;
      uptimeSeconds = 0;
      updateCounterEls();
    }

    function updateCounterEls() {
      msgSentEl.textContent = msgSent;
      msgRecvEl.textContent = msgRecv;
      frameTextEl.textContent = frameText;
      frameBinEl.textContent = frameBinary;
      framePingEl.textContent = framePingPong;
    }

    function transitionTo(state) {
      currentState = state;
      applyState(state);

      if (state === STATES.CLOSED) {
        clearInterval(uptimeTimer);
        uptimeTimer = null;
      }

      if (state === STATES.OPEN) {
        // start uptime counter
        uptimeTimer = setInterval(() => {
          uptimeSeconds++;
          uptimeVal.textContent = fmtUptime(uptimeSeconds);
        }, 1000);
      }

      if (stateTimer) clearTimeout(stateTimer);
      stateTimer = setTimeout(() => {
        const next = {
          [STATES.CONNECTING]: STATES.OPEN,
          [STATES.OPEN]: STATES.CLOSING,
          [STATES.CLOSING]: STATES.CLOSED,
          [STATES.CLOSED]: STATES.CONNECTING,
        }[state];

        if (next === STATES.CONNECTING) {
          resetCounters();
          clearFeed();
        }
        transitionTo(next);
      }, STATE_DURATIONS[state]);
    }

    // ============================================================
    // SPARKLINE
    // ============================================================
    const canvas = document.getElementById('sparklineCanvas');
    const ctx = canvas.getContext('2d');
    const sparkData = [];
    const SPARK_POINTS = 22;
    let currentLatency = 12;

    function nextLatency(prev) {
      const delta = (Math.random() - 0.48) * 5;
      return Math.max(7, Math.min(30, Math.round(prev + delta)));
    }

    // Seed sparkline
    for (let i = 0; i < SPARK_POINTS; i++) {
      currentLatency = nextLatency(currentLatency);
      sparkData.push(currentLatency);
    }

    function drawSparkline() {
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);

      if (sparkData.length < 2) return;

      const minV = Math.min(...sparkData) - 2;
      const maxV = Math.max(...sparkData) + 2;
      const range = maxV - minV || 1;

      const step = w / (SPARK_POINTS - 1);

      // gradient fill
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, 'rgba(13,148,136,0.18)');
      grad.addColorStop(1, 'rgba(13,148,136,0)');

      ctx.beginPath();
      sparkData.forEach((v, i) => {
        const x = i * step;
        const y = h - ((v - minV) / range) * (h - 4) - 2;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      // close path for fill
      const lastX = (SPARK_POINTS - 1) * step;
      const lastY = h - ((sparkData[sparkData.length - 1] - minV) / range) * (h - 4) - 2;
      ctx.lineTo(lastX, h);
      ctx.lineTo(0, h);
      ctx.closePath();
      ctx.fillStyle = grad;
      ctx.fill();

      // line
      ctx.beginPath();
      sparkData.forEach((v, i) => {
        const x = i * step;
        const y = h - ((v - minV) / range) * (h - 4) - 2;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.strokeStyle = '#0d9488';
      ctx.lineWidth = 1.5;
      ctx.lineJoin = 'round';
      ctx.stroke();

      // current dot
      const cx = lastX;
      const cy = lastY;
      ctx.beginPath();
      ctx.arc(cx, cy, 2.5, 0, Math.PI * 2);
      ctx.fillStyle = '#0d9488';
      ctx.fill();
    }

    // rAF loop for sparkline
    let lastSparkUpdate = 0;
    function sparkLoop(ts) {
      if (ts - lastSparkUpdate > 1100) {
        currentLatency = nextLatency(currentLatency);
        sparkData.push(currentLatency);
        if (sparkData.length > SPARK_POINTS) sparkData.shift();
        latencyEl.textContent = currentLatency;
        lastSparkUpdate = ts;
      }
      drawSparkline();
      sparkRAF = requestAnimationFrame(sparkLoop);
    }
    let sparkRAF = requestAnimationFrame(sparkLoop);

    // ============================================================
    // MESSAGE FEED
    // ============================================================
    const MAX_FEED_LINES = 7;
    const feedLines = [];

    function nowTs() {
      const d = new Date();
      return `${padZ(d.getHours())}:${padZ(d.getMinutes())}:${padZ(d.getSeconds())}.${String(d.getMilliseconds()).padStart(3, '0')}`;
    }

    const MESSAGE_TEMPLATES = [
      // client -> server
      { dir: 'client', type: 'TEXT', payload: '"subscribe" {"channel":"updates"}' },
      { dir: 'client', type: 'TEXT', payload: '"heartbeat" {"ts":1711814585}' },
      { dir: 'client', type: 'TEXT', payload: '"query" {"metric":"connections","window":"5m"}' },
      { dir: 'client', type: 'TEXT', payload: '"auth" {"token":"eyJhb..."}' },
      { dir: 'client', type: 'TEXT', payload: '"publish" {"channel":"events","data":"..."}' },
      { dir: 'client', type: 'PING', payload: null },
      // server -> client
      { dir: 'server', type: 'TEXT', payload: '"subscribed" {"channel":"updates","id":"ch_29x"}' },
      { dir: 'server', type: 'TEXT', payload: '"message" {"data":"Pool: 2.4M active"}' },
      { dir: 'server', type: 'TEXT', payload: '"event" {"type":"connect","peer":"10.0.1.42"}' },
      { dir: 'server', type: 'TEXT', payload: '"metrics" {"latency_p99":"18ms","msgs_sec":4210}' },
      { dir: 'server', type: 'TEXT', payload: '"ack" {"id":"pub_7741","status":"ok"}' },
      {
        dir: 'server',
        type: 'BINARY',
        payload: '[1.2KB] frame_seq=' + (4800 + Math.floor(Math.random() * 200)),
      },
      { dir: 'server', type: 'PONG', payload: `[${currentLatency}ms]` },
    ];

    let templateIdx = 0;
    // Track pending PING so PONG always pairs with it
    let pendingPing = false;

    function buildFeedLine(tpl) {
      const ts = nowTs();
      const dir = tpl.dir === 'client' ? '→' : '←';
      const dirCls = tpl.dir === 'client' ? 'db-feed-dir-client' : 'db-feed-dir-server';
      const payloadCls = tpl.dir === 'client' ? 'client' : 'server';
      const payload = tpl.payload
        ? `<span class="db-feed-payload ${payloadCls}">${tpl.payload}</span>`
        : '';

      const line = document.createElement('div');
      line.className = 'db-feed-line';
      line.innerHTML =
        `<span class="db-feed-ts">${ts}</span>` +
        `<span class="${dirCls}">${dir}</span>` +
        `<span class="db-feed-type">${tpl.type}</span>` +
        payload;
      return line;
    }

    function clearFeed() {
      feedLines.length = 0;
      feedInner.innerHTML = '';
      pendingPing = false;
    }

    function addFeedLine(tpl) {
      const lineEl = buildFeedLine(tpl);
      feedLines.push(lineEl);
      feedInner.appendChild(lineEl);

      // Trim old lines
      if (feedLines.length > MAX_FEED_LINES) {
        const old = feedLines.shift();
        old.classList.add('fade-out');
        setTimeout(() => {
          if (old.parentNode) old.parentNode.removeChild(old);
        }, 420);
      }
    }

    function pushFeedLine() {
      if (currentState !== STATES.OPEN) return;

      // If there's a pending PING, force the PONG next (keeps them paired)
      let tpl;
      if (pendingPing) {
        tpl = { dir: 'server', type: 'PONG', payload: `[${currentLatency}ms]` };
        pendingPing = false;
        // PONG increments the shared PING/PONG counter (already incremented on PING)
        msgRecv++;
        updateCounterEls();
        addFeedLine(tpl);
        return;
      }

      tpl = MESSAGE_TEMPLATES[templateIdx % MESSAGE_TEMPLATES.length];
      templateIdx++;

      // Update counters
      if (tpl.dir === 'client') {
        msgSent++;
        if (tpl.type === 'TEXT') {
          frameText++;
        }
        if (tpl.type === 'BINARY') {
          frameBinary++;
        }
        if (tpl.type === 'PING') {
          framePingPong++; // paired counter increments once for the PING/PONG pair
          pendingPing = true;
        }
      } else {
        // Skip PONG templates from the pool — handled above via pendingPing
        if (tpl.type === 'PONG') {
          tpl = MESSAGE_TEMPLATES[templateIdx % MESSAGE_TEMPLATES.length];
          templateIdx++;
          // re-check, use next non-PONG template
          if (tpl.type === 'PONG') {
            tpl = { dir: 'server', type: 'TEXT', payload: '"keepalive" {"ts":' + Date.now() + '}' };
          }
        }
        msgRecv++;
        if (tpl.type === 'TEXT') {
          frameText++;
        }
        if (tpl.type === 'BINARY') {
          frameBinary++;
        }
      }
      updateCounterEls();
      addFeedLine(tpl);
    }

    // Irregular intervals — feels more realistic
    function scheduleFeedLine() {
      if (currentState === STATES.OPEN) {
        pushFeedLine();
      }
      const delay = 900 + Math.random() * 1400;
      setTimeout(scheduleFeedLine, delay);
    }

    // ============================================================
    // PROTOCOL ANIMATION (IntersectionObserver)
    // ============================================================
    function animateProtoRows(container, delayBetween, repeatDelay) {
      const rows = container.querySelectorAll('.proto-row');

      function runCycle() {
        rows.forEach((r) => {
          r.style.opacity = '0';
          const line = r.querySelector('.proto-arrow-line');
          const head = r.querySelector('.proto-arrow-head');
          if (line) {
            line.style.width = '0';
            line.style.transition = 'none';
          }
          if (head) {
            head.style.opacity = '0';
            head.style.transition = 'none';
          }
        });

        rows.forEach((row, i) => {
          setTimeout(() => {
            row.style.transition = 'opacity 0.2s';
            row.style.opacity = '1';
            const line = row.querySelector('.proto-arrow-line');
            const head = row.querySelector('.proto-arrow-head');
            if (line) {
              requestAnimationFrame(() => {
                line.style.transition = 'width 0.35s ease-out';
                line.style.width = '100%';
              });
            }
            if (head) {
              setTimeout(() => {
                head.style.transition = 'opacity 0.15s';
                head.style.opacity = '1';
              }, 350);
            }
          }, i * delayBetween);
        });

        setTimeout(runCycle, repeatDelay);
      }

      runCycle();
    }

    // ============================================================
    // CARD REVEAL (IntersectionObserver)
    // ============================================================
    function initReveal() {
      const cards = document.querySelectorAll('[data-reveal]');
      if (!('IntersectionObserver' in window)) {
        cards.forEach((c) => c.classList.add('visible'));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const card = entry.target;
              const idx = Array.from(cards).indexOf(card);
              setTimeout(() => card.classList.add('visible'), idx * 100);
              observer.unobserve(card);
            }
          });
        },
        { threshold: 0.1 }
      );

      cards.forEach((c) => observer.observe(c));
    }

    function initProtoAnimations() {
      const cols = [
        { id: 'protoHttp', delay: 420, repeat: 3200 },
        { id: 'protoSse', delay: 320, repeat: 2600 },
        { id: 'protoWs', delay: 150, repeat: 1400 },
      ];

      if (!('IntersectionObserver' in window)) {
        cols.forEach((c) => {
          const el = document.getElementById(c.id);
          if (el) animateProtoRows(el, c.delay, c.repeat);
        });
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const col = cols.find((c) => c.id === entry.target.id);
              if (col) animateProtoRows(entry.target, col.delay, col.repeat);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );

      cols.forEach((c) => {
        const el = document.getElementById(c.id);
        if (el) observer.observe(el);
      });
    }

    // ============================================================
    // SEARCH (Pagefind)
    // ============================================================
    let pagefindInitialized = false;

    async function openSearch() {
      const dialog = document.getElementById('searchDialog');
      if (!dialog) return;
      dialog.showModal();

      if (!pagefindInitialized) {
        pagefindInitialized = true;

        // Load Pagefind CSS
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        try {
          const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
          new PagefindUI({
            element: '#searchTarget',
            bundlePath: '/pagefind/',
            showImages: false,
            showSubResults: true,
          });
        } catch (e) {
          // Pagefind not built yet (dev mode)
          document.getElementById('searchTarget').innerHTML =
            '<p style="padding:16px;color:var(--text-muted);font-size:0.88rem;">Search index not available in development mode. Run a production build to enable search.</p>';
        }
      }
    }

    function initSearch() {
      const dialog = document.getElementById('searchDialog');
      const openBtn = document.getElementById('searchBtn');
      const closeBtn = document.getElementById('searchClose');

      if (openBtn) {
        openBtn.addEventListener('click', openSearch);
      }

      if (closeBtn) {
        closeBtn.addEventListener('click', () => dialog && dialog.close());
      }

      // Close on backdrop click
      if (dialog) {
        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) dialog.close();
        });
      }

      // Cmd+K / Ctrl+K
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape' && dialog && dialog.open) {
          dialog.close();
        }
      });
    }

    // ============================================================
    // MOBILE NAV
    // ============================================================
    function initMobileNav() {
      const hamburger = document.getElementById('navHamburger');
      const mobileMenu = document.getElementById('navMobileMenu');

      if (!hamburger || !mobileMenu) return;

      hamburger.addEventListener('click', () => {
        const isOpen = mobileMenu.classList.toggle('open');
        hamburger.setAttribute('aria-expanded', String(isOpen));
      });

      // Close when a link is clicked
      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          hamburger.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // ============================================================
    // BOOT
    // ============================================================
    applyState(STATES.CONNECTING);
    transitionTo(STATES.CONNECTING);
    setTimeout(scheduleFeedLine, 2200); // start feed after connecting -> open
    initReveal();
    initProtoAnimations();
    initSearch();
    initMobileNav();

    // Dynamic copyright year
    const yearEl = document.getElementById('copyrightYear');
    if (yearEl) yearEl.textContent = new Date().getFullYear();

    // Pause animations when tab is hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(sparkRAF);
      } else {
        sparkRAF = requestAnimationFrame(sparkLoop);
      }
    });
  </script>
</BaseLayout>
